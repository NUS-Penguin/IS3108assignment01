<dashboard_requirements>

<specifications>
The admin dashboard (route: /admin/dashboard) MUST display:

1. Summary Statistics (cards):
   - Total active movies (count where in database)
   - Total cinema halls (count where status = 'active')
   - Screenings scheduled today (count where date = today)
   - Total screenings this week (optional)

2. Upcoming Screenings Table:
   - Show next 10 upcoming screenings
   - Columns: Movie Title, Hall Name, Start Time, Duration, Actions
   - Sorted by startTime ascending (earliest first)
   - Include Edit and Delete buttons

3. Quick Actions:
   - Button to create new screening
   - Button to add new movie
   - Button to add new hall

</specifications>

<implementation_example>
```javascript
// controllers/dashboardController.js

const Movie = require('../models/Movie');
const Hall = require('../models/Hall');
const Screening = require('../models/Screening');

exports.index = async (req, res, next) => {
  try {
    // Get current date for "today" calculations
    const now = new Date();
    const todayStart = new Date(now.setHours(0, 0, 0, 0));
    const todayEnd = new Date(now.setHours(23, 59, 59, 999));
    
    // Statistics
    const activeMovies = await Movie.countDocuments();
    const activeHalls = await Hall.countDocuments({ status: 'active' });
    const screeningsToday = await Screening.countDocuments({
      date: {
        $gte: todayStart,
        $lte: todayEnd
      }
    });
    
    // Upcoming screenings
    const upcomingScreenings = await Screening.find({
      startTime: { $gt: new Date() }
    })
      .populate('movie', 'title durationMinutes')
      .populate('hall', 'name')
      .sort({ startTime: 1 })
      .limit(10);
    
    res.render('dashboard/index', {
      title: 'Dashboard',
      username: req.session.username,
      stats: {
        activeMovies,
        activeHalls,
        screeningsToday
      },
      upcomingScreenings,
      flash: req.session.flash
    });
    
    // Clear flash message
    req.session.flash = null;
    
  } catch (error) {
    next(error);
  }
};
```
</implementation_example>

