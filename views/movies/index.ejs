<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-camera-reels me-2"></i>Movies</h2>
    <a href="/admin/movies/new" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i> Add New Movie
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <% if (movies && movies.length> 0) { %>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th>Genre</th>
                            <th>Duration</th>
                            <th>Release Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% movies.forEach(movie=> { %>
                            <tr>
                                <td>
                                    <strong>
                                        <%= movie.title %>
                                    </strong>
                                    <br>
                                    <small class="text-muted">
                                        <%= movie.description.substring(0, 60) %>...
                                    </small>
                                </td>
                                <td><span class="badge bg-info">
                                        <%= movie.genre %>
                                    </span></td>
                                <td>
                                    <%= movie.durationMinutes %> min
                                </td>
                                <td>
                                    <%= movie.releaseDate.toLocaleDateString('en-US', { month: 'short' , day: 'numeric'
                                        , year: 'numeric' }) %>
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a href="/admin/movies/<%= movie._id %>/edit"
                                            class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        <form action="/admin/movies/<%= movie._id %>?_method=DELETE" method="POST"
                                            class="d-inline"
                                            onsubmit="return confirm('Delete this movie? Cannot delete if screenings exist.');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                    </tbody>
                </table>
            </div>
            <% } else { %>
                <div class="text-center p-5 text-muted">
                    <i class="bi bi-camera-reels" style="font-size: 4rem;"></i>
                    <p class="mt-3 lead">No movies found</p>
                    <p>Start by adding your first movie</p>
                    <a href="/admin/movies/new" class="btn btn-primary mt-2">
                        <i class="bi bi-plus-circle me-2"></i> Add First Movie
                    </a>
                </div>
                <% } %>
    </div>
</div>