<%# views/movies/index.ejs - Movie Catalogue with Search, Filters, Poster & Status %>

<div class="page-header">
    <h1>Movies</h1>
    <p>Manage movie catalogue, availability, and screening dependencies.</p>
</div>

<div class="action-buttons">
    <a href="/admin/movies/new" class="action-btn primary">Add New Movie</a>
</div>

<%# ── Search & Filter Form ─────────────────────────────────────────── %>
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form action="/admin/movies" method="GET" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label for="search" class="form-label fw-semibold">
                    <i class="bi bi-search me-1"></i>Search
                </label>
                <input type="text" class="form-control" id="search" name="search"
                    placeholder="Search by title..." value="<%= filters.search %>">
            </div>

            <div class="col-md-2">
                <label for="genre" class="form-label fw-semibold">Genre</label>
                <select class="form-select" id="genre" name="genre">
                    <option value="">All Genres</option>
                    <% genres.forEach(g => { %>
                        <option value="<%= g %>" <%= filters.genre === g ? 'selected' : '' %>><%= g %></option>
                    <% }); %>
                </select>
            </div>

            <div class="col-md-2">
                <label for="status" class="form-label fw-semibold">Status</label>
                <select class="form-select" id="status" name="status">
                    <option value="">All Statuses</option>
                    <% statuses.forEach(s => { %>
                        <option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= s %></option>
                    <% }); %>
                </select>
            </div>

            <div class="col-md-2">
                <label for="releaseYear" class="form-label fw-semibold">Release Year</label>
                <input type="number" class="form-control" id="releaseYear" name="releaseYear"
                    placeholder="e.g. 2024" min="1900" max="2100"
                    value="<%= filters.releaseYear %>">
            </div>

            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="action-btn primary flex-fill">
                    <i class="bi bi-funnel me-1"></i>Filter
                </button>
                <a href="/admin/movies" class="action-btn">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<%# ── Results ─────────────────────────────────────────────────────── %>
<div class="card shadow-sm">
    <div class="card-body p-0">

        <% if (movies && movies.length > 0) { %>
            <%# Result count badge %>
            <div class="d-flex align-items-center px-3 pt-3 pb-2 border-bottom">
                <span class="text-muted small">
                    Showing <strong><%= movies.length %></strong> movie<%= movies.length !== 1 ? 's' : '' %>
                </span>
            </div>

            <div class="table-responsive">
                <table class="market-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="text-nowrap" scope="col">Poster</th>
                            <th>Title</th>
                            <th>Genre</th>
                            <th>Duration</th>
                            <th>Release Date</th>
                            <th>Status</th>
                            <th>Screenings</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% movies.forEach(movie => { %>
                            <%
                                // Status badge colour
                                const statusBadge =
                                    movie.status === 'Now Showing'  ? 'bg-success' :
                                    movie.status === 'Coming Soon'  ? 'bg-warning text-dark' :
                                                                      'bg-secondary';
                            %>
                            <tr>
                                <%# Poster thumbnail %>
                                <td>
                                    <% if (movie.posterURL) { %>
                                        <img src="<%= movie.posterURL %>"
                                             alt="<%= movie.title %> poster"
                                             class="rounded"
                                             width="48" height="68"
                                             onerror="this.src='https://via.placeholder.com/48x68?text=N/A'">
                                    <% } else { %>
                                        <div class="bg-light rounded d-flex align-items-center justify-content-center text-muted p-3">
                                            <i class="bi bi-film fs-5"></i>
                                        </div>
                                    <% } %>
                                </td>

                                <%# Title + description preview %>
                                <td>
                                    <div class="fw-semibold"><%= movie.title %></div>
                                    <small class="text-muted">
                                        <%= movie.description.substring(0, 70) %><%= movie.description.length > 70 ? '…' : '' %>
                                    </small>
                                </td>

                                <%# Genre %>
                                <td><span class="badge bg-info text-dark"><%= movie.genre %></span></td>

                                <%# Duration %>
                                <td>
                                    <span class="text-nowrap">
                                        <i class="bi bi-clock me-1 text-muted"></i>
                                        <%= movie.durationFormatted %>
                                    </span>
                                </td>

                                <%# Release date %>
                                <td class="text-nowrap">
                                    <%= new Date(movie.releaseDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                                </td>

                                <%# Status badge %>
                                <td>
                                    <span class="badge <%= statusBadge %>"><%= movie.status %></span>
                                </td>

                                <%# Future screenings count %>
                                <td>
                                    <% if (movie.futureScreeningsCount > 0) { %>
                                        <span class="badge bg-primary rounded-pill">
                                            <%= movie.futureScreeningsCount %> upcoming
                                        </span>
                                    <% } else { %>
                                        <span class="text-muted small">None</span>
                                    <% } %>
                                </td>

                                <%# Action buttons %>
                                <td class="text-end">
                                    <div class="btn-group" role="group">
                                        <a href="/admin/movies/<%= movie._id %>/edit"
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil me-1"></i>Edit
                                        </a>

                                        <% if (movie.futureScreeningsCount > 0) { %>
                                            <%# Disabled delete with tooltip when screenings exist %>
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-danger"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#cannotDeleteModal"
                                                    data-title="<%= movie.title %>"
                                                    data-count="<%= movie.futureScreeningsCount %>">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        <% } else { %>
                                            <form action="/admin/movies/<%= movie._id %>?_method=DELETE"
                                                  method="POST" class="d-inline"
                                                  onsubmit="return confirm('Delete \'<%= movie.title %>\'? This action cannot be undone.');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

        <% } else { %>
            <div class="text-center py-5 text-muted">
                <i class="bi bi-camera-reels display-1"></i>
                <p class="mt-3 lead">No movies found</p>
                <% if (filters.search || filters.genre || filters.status || filters.releaseYear) { %>
                    <p>Try adjusting your search or filter criteria.</p>
                    <a href="/admin/movies" class="action-btn mt-2">
                        <i class="bi bi-x-circle me-2"></i>Clear Filters
                    </a>
                <% } else { %>
                    <p>Start by adding your first movie.</p>
                    <a href="/admin/movies/new" class="action-btn primary mt-2">
                        <i class="bi bi-plus-circle me-2"></i>Add First Movie
                    </a>
                <% } %>
            </div>
        <% } %>

    </div>
</div>

<%# ── Cannot-Delete Info Modal ────────────────────────────────────── %>
<div class="modal fade" id="cannotDeleteModal" tabindex="-1" aria-labelledby="cannotDeleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="cannotDeleteModalLabel">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>Cannot Delete Movie
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="cannotDeleteModalBody">
                <%# Content is injected by the script below %>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <a href="/admin/screenings" class="btn btn-primary">
                    <i class="bi bi-calendar-event me-1"></i>Manage Screenings
                </a>
            </div>
        </div>
    </div>
</div>

<script>
    // Populate modal with movie-specific info before it shows
    const cannotDeleteModal = document.getElementById('cannotDeleteModal');
    cannotDeleteModal.addEventListener('show.bs.modal', event => {
        const btn = event.relatedTarget;
        const title = btn.getAttribute('data-title');
        const count = parseInt(btn.getAttribute('data-count'), 10);
        const plural = count === 1 ? 'screening' : 'screenings';
        document.getElementById('cannotDeleteModalBody').innerHTML =
            `<p>
                <strong>"${title}"</strong> has
                <span class="badge bg-primary">${count}</span>
                future ${plural} scheduled.
             </p>
             <p class="mb-0">Please remove or reschedule them before deleting this movie.</p>`;
    });
</script>
