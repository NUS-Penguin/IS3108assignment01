<%
  // Determine mode
  const isEditMode = typeof movie !== 'undefined' && movie;
  const formAction     = isEditMode ? `/admin/movies/${movie._id}?_method=PUT` : '/admin/movies';
  const formTitle      = isEditMode ? 'Edit Movie' : 'Add New Movie';
  const formIcon       = isEditMode ? 'bi-pencil' : 'bi-plus-circle';
  const submitButtonText = isEditMode ? 'Update Movie' : 'Add Movie';

  // Pre-fill values
  const movieTitle       = isEditMode ? movie.title       : '';
  const movieDescription = isEditMode ? movie.description : '';
  const movieDuration    = isEditMode ? movie.durationMinutes : '';
  const movieGenre       = isEditMode ? movie.genre       : '';
  const movieReleaseDate = isEditMode ? new Date(movie.releaseDate).toISOString().split('T')[0] : '';
    const moviePosterPath  = isEditMode ? (movie.posterPath || movie.posterURL || '') : '';
  const movieStatus      = isEditMode ? movie.status      : 'Now Showing';
%>

<div class="page-header">
    <h1><%= formTitle %></h1>
    <p>Manage movie metadata, status, and poster details.</p>
</div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h4 class="mb-0"><i class="<%= formIcon %> me-2"></i>
                        <%= formTitle %>
                    </h4>
                </div>
                <div class="card-body">
                    <% if (error) { %>
                        <div class="alert alert-danger" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <%= error %>
                        </div>
                        <% } %>

                            <form action="<%= formAction %>" method="POST" enctype="multipart/form-data">
                                <div class="mb-3">
                                    <label for="title" class="form-label">Movie Title <span
                                            class="text-danger">*</span></label>
                                    <input type="text" class="form-control" id="title" name="title" required
                                        maxlength="200" value="<%= movieTitle %>" placeholder="e.g., The Matrix">
                                </div>

                                <div class="mb-3">
                                    <label for="description" class="form-label">Description <span
                                            class="text-danger">*</span></label>
                                    <textarea class="form-control" id="description" name="description" required rows="4"
                                        minlength="10" maxlength="1000"
                                        placeholder="Brief description of the movie"><%= movieDescription %></textarea>
                                    <div class="form-text">10-1000 characters</div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label for="durationMinutes" class="form-label">Duration (minutes) <span
                                                class="text-danger">*</span></label>
                                        <input type="number" class="form-control" id="durationMinutes"
                                            name="durationMinutes" required min="1" max="500"
                                            value="<%= movieDuration %>" placeholder="e.g., 120">
                                    </div>

                                    <div class="col-md-6 mb-3">
                                        <label for="genre" class="form-label">Genre <span
                                                class="text-danger">*</span></label>
                                        <select class="form-select" id="genre" name="genre" required>
                                            <% if (!isEditMode) { %>
                                                <option value="">Select genre...</option>
                                                <% } %>
                                                    <% genres.forEach(genre=> { %>
                                                        <option value="<%= genre %>" <%=movieGenre===genre ? 'selected'
                                                            : '' %>>
                                                            <%= genre %>
                                                        </option>
                                                        <% }); %>
                                        </select>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label for="releaseDate" class="form-label">Release Date <span
                                            class="text-danger">*</span></label>
                                    <input type="date" class="form-control" id="releaseDate" name="releaseDate" required
                                        value="<%= movieReleaseDate %>">
                                </div>

                                <%# Status field %>
                                <div class="mb-3">
                                    <label for="status" class="form-label fw-semibold">Status <span class="text-danger">*</span></label>
                                    <select class="form-select" id="status" name="status" required>
                                        <% statuses.forEach(s => { %>
                                            <option value="<%= s %>" <%= movieStatus === s ? 'selected' : '' %>><%= s %></option>
                                        <% }); %>
                                    </select>
                                    <div class="form-text">
                                        <span class="badge bg-success">Now Showing</span> – can be scheduled immediately &nbsp;
                                        <span class="badge bg-warning text-dark">Coming Soon</span> – cannot schedule until release date &nbsp;
                                        <span class="badge bg-secondary">Archived</span> – no new screenings allowed
                                    </div>
                                </div>

                                <%# Poster Upload with live preview %>
                                <div class="mb-3">
                                    <label for="poster" class="form-label fw-semibold">Poster Image <span class="text-muted">(optional)</span></label>
                                    <div class="d-flex gap-3 align-items-start">
                                        <div class="flex-fill">
                                            <input type="file" class="form-control" id="poster" name="poster" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp">
                                            <div class="form-text">Upload jpg, jpeg, png, or webp (max 5MB)</div>
                                        </div>
                                        <div id="posterPreviewWrapper" class="<%= moviePosterPath ? '' : 'd-none' %>">
                                            <img id="posterPreview"
                                                 src="<%= moviePosterPath || 'https://via.placeholder.com/80x112?text=No+Poster' %>"
                                                 alt="Poster preview"
                                                 class="rounded border"
                                                 width="80" height="112">
                                        </div>
                                    </div>
                                    <% if (!moviePosterPath) { %>
                                        <small id="posterEmptyText" class="text-muted">No poster uploaded</small>
                                    <% } else { %>
                                        <small id="posterEmptyText" class="text-muted d-none">No poster uploaded</small>
                                    <% } %>
                                </div>

                                <div class="d-flex gap-2">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-check-circle me-2"></i>
                                        <%= submitButtonText %>
                                    </button>
                                    <a href="/admin/movies" class="btn btn-secondary">
                                        <i class="bi bi-x-circle me-2"></i>Cancel
                                    </a>
                                </div>
                            </form>
                </div>
            </div>
        </div>
    </div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const posterInput = document.getElementById('poster');
    const wrapper = document.getElementById('posterPreviewWrapper');
    const img = document.getElementById('posterPreview');
    const emptyText = document.getElementById('posterEmptyText');

    if (!posterInput || !wrapper || !img) return;

    posterInput.addEventListener('change', function () {
        const file = this.files && this.files[0];
        if (!file) {
            return;
        }

        const reader = new FileReader();
        reader.onload = function (event) {
            img.src = event.target.result;
            wrapper.classList.remove('d-none');
            if (emptyText) {
                emptyText.classList.add('d-none');
            }
        };
        reader.readAsDataURL(file);
    });
});
</script>