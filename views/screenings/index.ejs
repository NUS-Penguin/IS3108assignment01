<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-calendar-event me-2"></i>Screenings</h2>
    <a href="/admin/screenings/new" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i> Create New Screening
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <% if (screenings && screenings.length> 0) { %>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Movie</th>
                            <th>Hall</th>
                            <th>Date & Time</th>
                            <th>Duration</th>
                            <th>Genre</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% screenings.forEach(screening=> { %>
                            <tr>
                                <td>
                                    <strong>
                                        <%= screening.movie.title %>
                                    </strong>
                                </td>
                                <td>
                                    <span class="badge bg-secondary">
                                        <%= screening.hall.name %>
                                    </span>
                                    <% if (screening.hall.status==='maintenance' ) { %>
                                        <span class="badge bg-warning text-dark ms-1">Maintenance</span>
                                        <% } %>
                                </td>
                                <td>
                                    <%= screening.startTime.toLocaleDateString('en-US', { month: 'short' ,
                                        day: 'numeric' , year: 'numeric' }) %>
                                        <br>
                                        <small class="text-muted">
                                            <%= screening.startTime.toLocaleTimeString('en-US', { hour: '2-digit' ,
                                                minute: '2-digit' }) %> -
                                                <%= screening.endTime.toLocaleTimeString('en-US', { hour: '2-digit' ,
                                                    minute: '2-digit' }) %>
                                        </small>
                                </td>
                                <td>
                                    <%= screening.movie.durationMinutes %> min
                                </td>
                                <td><span class="badge bg-info">
                                        <%= screening.movie.genre %>
                                    </span></td>
                                <td>
                                    <% if (screening.startTime> new Date()) { %>
                                        <span class="badge bg-success">Upcoming</span>
                                        <% } else if (screening.endTime> new Date()) { %>
                                            <span class="badge bg-warning text-dark">In Progress</span>
                                            <% } else { %>
                                                <span class="badge bg-secondary">Completed</span>
                                                <% } %>
                                </td>
                                <td>
                                    <form action="/admin/screenings/<%= screening._id %>?_method=DELETE" method="POST"
                                        class="d-inline" onsubmit="return confirm('Delete this screening?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            <% }); %>
                    </tbody>
                </table>
            </div>
            <% } else { %>
                <div class="text-center p-5 text-muted">
                    <i class="bi bi-calendar-x display-1"></i>
                    <p class="mt-3 lead">No screenings found</p>
                    <p>Start by creating your first screening</p>
                    <a href="/admin/screenings/new" class="btn btn-primary mt-2">
                        <i class="bi bi-plus-circle me-2"></i> Create First Screening
                    </a>
                </div>
                <% } %>
    </div>
</div>