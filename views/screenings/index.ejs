<div id="screeningScheduler"
     data-selected-date="<%= selectedDateValue %>"
    data-cleaning-buffer="<%= cleaningBufferMinutes %>"
    data-halls="<%- encodeURIComponent(JSON.stringify(timelineHalls || [])) %>"
    data-screenings="<%- encodeURIComponent(JSON.stringify(timelineScreenings || [])) %>">
    <div class="page-header">
        <h1>Screening Scheduler</h1>
        <p>Schedule screenings by timeline and hall capacity constraints.</p>
    </div>

    <div class="action-buttons">
        <a href="/admin/screenings/new" class="action-btn primary">Manual Form</a>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex flex-wrap align-items-center gap-2">
                <button id="timelinePrevDate" type="button" class="btn btn-outline-secondary" aria-label="Previous day">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <input id="timelineDatePicker" type="date" class="form-control w-auto" value="<%= selectedDateValue %>">
                <button id="timelineNextDate" type="button" class="btn btn-outline-secondary" aria-label="Next day">
                    <i class="bi bi-chevron-right"></i>
                </button>
                <button id="timelineToday" type="button" class="btn btn-outline-primary">Today</button>
                <div class="btn-group ms-md-2" role="group" aria-label="Schedule view toggle">
                    <button id="timelineViewAM" type="button" class="btn btn-primary">AM Schedule</button>
                    <button id="timelineViewPM" type="button" class="btn btn-outline-primary">PM Schedule</button>
                </div>
                <span class="text-muted small ms-md-3">
                    Cleaning buffer: <strong><%= cleaningBufferMinutes %> min before + <%= cleaningBufferMinutes %> min after</strong>
                </span>
            </div>
        </div>
    </div>

    <div id="timelineAlert" class="alert alert-warning d-none" role="alert"></div>

    <div class="row g-3">
        <div class="col-lg-9">
            <div class="card">
                <div class="card-body p-0">
                    <div class="scheduler-container">
                        <div id="timelineMasterGrid" class="timeline-master-grid"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-film me-2"></i>Movie Library</h5>
                </div>
                <div class="card-body">
                    <% if (movies && movies.length > 0) { %>
                        <div class="d-flex flex-column gap-2" id="timelineMovieLibrary">
                            <% movies.forEach((movie) => { %>
                                <button
                                    type="button"
                                    class="btn btn-outline-secondary text-start timeline-movie-item"
                                    draggable="true"
                                    data-movie-id="<%= movie._id %>"
                                    data-duration="<%= movie.durationMinutes %>"
                                    data-title="<%= movie.title %>">
                                    <span class="fw-semibold d-block"><%= movie.title %></span>
                                    <small class="text-muted"><%= movie.durationMinutes %> min • <%= movie.genre %></small>
                                    <span class="movie-duration-bar" aria-hidden="true"></span>
                                </button>
                            <% }); %>
                        </div>
                    <% } else { %>
                        <p class="text-muted mb-0">No movies available for scheduling.</p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <p class="text-muted small mt-3 mb-0">
        Drag a movie into a hall row to schedule. Drag an existing block to move. Click a block to edit; use the
        delete icon to remove.
    </p>
</div>
