<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create New Screening</h4>
            </div>
            <div class="card-body">
                <% if (error) { %>
                    <div class="alert alert-danger" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <%= error %>
                    </div>
                    <% } %>

                        <div class="alert alert-info" role="alert">
                            <i class="bi bi-info-circle me-2"></i>
                            <strong>Important:</strong> The system will automatically check for screening overlaps
                            in the same hall.
                            Screenings cannot overlap on the same date.
                        </div>

                        <form action="/admin/screenings" method="POST">
                            <div class="mb-3">
                                <label for="movie" class="form-label">Select Movie <span
                                        class="text-danger">*</span></label>
                                <select class="form-select" id="movie" name="movie" required>
                                    <option value="">Choose a movie...</option>
                                    <% movies.forEach(movie=> { %>
                                        <option value="<%= movie._id %>" data-duration="<%= movie.durationMinutes %>">
                                            <%= movie.title %> (<%= movie.durationMinutes %> min)
                                        </option>
                                        <% }); %>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label for="hall" class="form-label">Select Hall <span
                                        class="text-danger">*</span></label>
                                <select class="form-select" id="hall" name="hall" required>
                                    <option value="">Choose a hall...</option>
                                    <% halls.forEach(hall=> { %>
                                        <option value="<%= hall._id %>">
                                            <%= hall.name %> (<%= hall.rows * hall.columns %> seats)
                                        </option>
                                        <% }); %>
                                </select>
                                <% if (!halls || halls.length===0) { %>
                                    <div class="form-text text-danger">
                                        <i class="bi bi-exclamation-triangle me-1"></i>
                                        No active halls available. Please create a hall first.
                                    </div>
                                    <% } %>
                            </div>

                            <div class="mb-3">
                                <label for="startTime" class="form-label">Start Date & Time <span
                                        class="text-danger">*</span></label>
                                <input type="datetime-local" class="form-control" id="startTime" name="startTime"
                                    required>
                                <div class="form-text">
                                    Select a future date and time. The end time will be calculated automatically
                                    based on movie duration.
                                </div>
                            </div>

                            <div id="endTimePreview" class="alert alert-secondary d-none">
                                <strong>Estimated End Time:</strong> <span id="endTimeValue">-</span>
                            </div>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary" <%=(!movies || movies.length===0 || !halls
                                    || halls.length===0) ? 'disabled' : '' %>>
                                    <i class="bi bi-check-circle me-2"></i> Create Screening
                                </button>
                                <a href="/admin/screenings" class="btn btn-secondary">
                                    <i class="bi bi-x-circle me-2"></i> Cancel
                                </a>
                            </div>
                        </form>
            </div>
        </div>
    </div>
</div>

<script>
    // Calculate and display end time based on movie selection and start time
    document.addEventListener('DOMContentLoaded', function () {
        const movieSelect = document.getElementById('movie');
        const startTimeInput = document.getElementById('startTime');
        const endTimePreview = document.getElementById('endTimePreview');
        const endTimeValue = document.getElementById('endTimeValue');

        function updateEndTime() {
            const selectedMovie = movieSelect.options[movieSelect.selectedIndex];
            const duration = selectedMovie.dataset.duration;
            const startTime = startTimeInput.value;

            if (duration && startTime) {
                const start = new Date(startTime);
                const end = new Date(start.getTime() + duration * 60000);

                endTimeValue.textContent = end.toLocaleString('en-US', {
                    month: 'short',
                    day: 'numeric',
                    year: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit'
                });

                endTimePreview.classList.remove('d-none');
            } else {
                endTimePreview.classList.add('d-none');
            }
        }

        movieSelect.addEventListener('change', updateEndTime);
        startTimeInput.addEventListener('change', updateEndTime);

        // Set minimum datetime to current time
        const now = new Date();
        now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
        startTimeInput.min = now.toISOString().slice(0, 16);
    });
</script>