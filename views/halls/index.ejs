<div class="page-header">
    <h1>Cinema Halls</h1>
    <p>Manage hall capacity, status, and seat configuration.</p>
</div>

<div class="action-buttons">
    <a href="/admin/halls/new" class="action-btn primary">Add New Hall</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <% if (halls && halls.length> 0) { %>
            <div class="table-responsive">
                <table class="market-table">
                    <thead>
                        <tr>
                            <th>Hall Name</th>
                            <th>Capacity</th>
                            <th>Configuration</th>
                            <th>Status</th>
                            <th>Maintenance</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% halls.forEach(hall=> { %>
                            <tr>
                                <td>
                                    <strong>
                                        <%= hall.name %>
                                    </strong>
                                    <br>
                                    <small class="text-muted">
                                        <%= hall.rows %> rows × <%= hall.columns %> columns
                                    </small>
                                </td>
                                <td>
                                    <strong>
                                        <%= hall.capacity %>
                                    </strong> seats
                                </td>
                                <td>
                                    <% if (hall.seatTypes && hall.seatTypes.length> 0) { %>
                                        <small>
                                            <% hall.seatTypes.forEach((seat, index)=> { %>
                                                <span class="badge bg-secondary">
                                                    <% if (seat.type==='regular' ) { %>
                                                        <i class="bi bi-circle"></i> Regular: <%= seat.count %>
                                                            <% } else if (seat.type==='vip' ) { %>
                                                                <i class="bi bi-star-fill"></i> VIP: <%= seat.count %>
                                                                    <% } else if (seat.type==='wheelchair' ) { %>
                                                                        <i class="bi bi-person-wheelchair"></i>
                                                                        Wheelchair: <%= seat.count %>
                                                                            <% } %>
                                                </span>
                                                <% if (index < hall.seatTypes.length - 1) { %>
                                                    <% } %>
                                                        <% }); %>
                                        </small>
                                        <% } else { %>
                                            <small class="text-muted">All Regular</small>
                                            <% } %>
                                </td>
                                <td>
                                    <% if (hall.status==='active' ) { %>
                                        <span class="badge bg-success">
                                            <i class="bi bi-check-circle"></i> Active
                                        </span>
                                        <% } else if (hall.status==='maintenance' ) { %>
                                            <span class="badge bg-danger">
                                                <i class="bi bi-tools"></i> Maintenance
                                            </span>
                                            <% } else if (hall.status==='cleaning' ) { %>
                                                <span class="badge bg-warning text-dark">
                                                    <i class="bi bi-droplet"></i> Cleaning
                                                </span>
                                                <% } %>
                                </td>
                                <td>
                                    <% if (hall.status==='maintenance' && hall.maintenanceStartDate &&
                                        hall.maintenanceEndDate) { %>
                                        <small>
                                            <%= hall.maintenanceStartDate.toLocaleDateString('en-US', { month: 'short' ,
                                                day: 'numeric' }) %>
                                                –
                                                <%= hall.maintenanceEndDate.toLocaleDateString('en-US', { month: 'short'
                                                    , day: 'numeric' }) %>
                                        </small>
                                        <% if (hall.maintenanceReason) { %>
                                            <br>
                                            <small class="text-muted">
                                                <%= hall.maintenanceReason %>
                                            </small>
                                            <% } %>
                                                <% } else { %>
                                                    <span class="text-muted">–</span>
                                                    <% } %>
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a href="/admin/halls/<%= hall._id %>" class="btn btn-sm btn-outline-info"
                                            title="View Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a href="/admin/halls/<%= hall._id %>/edit"
                                            class="btn btn-sm btn-outline-primary" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form action="/admin/halls/<%= hall._id %>?_method=DELETE" method="POST"
                                            class="d-inline"
                                            onsubmit="return confirm('Are you sure you want to delete this hall?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                    </tbody>
                </table>
            </div>
            <% } else { %>
                <div class="text-center p-5 text-muted">
                    <i class="bi bi-building display-1 opacity-25"></i>
                    <p class="mt-3 lead">No cinema halls found</p>
                    <p>Start by adding your first cinema hall</p>
                    <a href="/admin/halls/new" class="action-btn primary mt-2">
                        <i class="bi bi-plus-circle me-2"></i> Add First Hall
                    </a>
                </div>
                <% } %>
    </div>
</div>