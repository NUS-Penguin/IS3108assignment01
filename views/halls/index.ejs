<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-building me-2"></i>Cinema Halls</h2>
    <a href="/admin/halls/new" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i> Add New Hall
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <% if (halls && halls.length> 0) { %>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Hall Name</th>
                            <th>Rows</th>
                            <th>Columns</th>
                            <th>Total Seats</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% halls.forEach(hall=> { %>
                            <tr>
                                <td><strong>
                                        <%= hall.name %>
                                    </strong></td>
                                <td>
                                    <%= hall.rows %>
                                </td>
                                <td>
                                    <%= hall.columns %>
                                </td>
                                <td>
                                    <%= hall.rows * hall.columns %> seats
                                </td>
                                <td>
                                    <% if (hall.status==='active' ) { %>
                                        <span class="badge bg-success">Active</span>
                                        <% } else { %>
                                            <span class="badge bg-warning text-dark">Maintenance</span>
                                            <% } %>
                                </td>
                                <td>
                                    <%= hall.createdAt.toLocaleDateString('en-US', { month: 'short' , day: 'numeric' ,
                                        year: 'numeric' }) %>
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a href="/admin/halls/<%= hall._id %>/edit"
                                            class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        <form action="/admin/halls/<%= hall._id %>?_method=DELETE" method="POST"
                                            class="d-inline"
                                            onsubmit="return confirm('Are you sure you want to delete this hall?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                    </tbody>
                </table>
            </div>
            <% } else { %>
                <div class="text-center p-5 text-muted">
                    <i class="bi bi-building" style="font-size: 4rem;"></i>
                    <p class="mt-3 lead">No cinema halls found</p>
                    <p>Start by adding your first cinema hall</p>
                    <a href="/admin/halls/new" class="btn btn-primary mt-2">
                        <i class="bi bi-plus-circle me-2"></i> Add First Hall
                    </a>
                </div>
                <% } %>
    </div>
</div>