<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0"><i class="bi bi-pencil me-2"></i>Edit Cinema Hall</h4>
            </div>
            <div class="card-body">
                <% if (error) { %>
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <%= error %>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                    <% } %>

                        <form action="/admin/halls/<%= hall._id %>?_method=PUT" method="POST" id="hallForm">

                            <!-- Basic Information -->
                            <h5 class="border-bottom pb-2 mb-3"><i class="bi bi-info-circle me-2"></i>Basic Information
                            </h5>

                            <div class="mb-3">
                                <label for="name" class="form-label">Hall Name <span
                                        class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="name" name="name" required
                                    value="<%= hall.name %>">
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="rows" class="form-label">Number of Rows <span
                                            class="text-danger">*</span></label>
                                    <input type="number" class="form-control" id="rows" name="rows" required min="1"
                                        max="26" value="<%= hall.rows %>">
                                    <div class="form-text">1-26 rows (A-Z)</div>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label for="columns" class="form-label">Number of Columns <span
                                            class="text-danger">*</span></label>
                                    <input type="number" class="form-control" id="columns" name="columns" required
                                        min="1" max="50" value="<%= hall.columns %>">
                                    <div class="form-text">1-50 columns</div>
                                </div>
                            </div>

                            <div class="alert alert-info mb-4">
                                <i class="bi bi-calculator me-2"></i>
                                <strong>Automatic Capacity Calculation:</strong>
                                <span id="capacityDisplay">
                                    <%= hall.capacity %> seats (<%= hall.rows %> rows × <%= hall.columns %> columns)
                                </span>
                            </div>

                            <!-- Seat Type Configuration -->
                            <h5 class="border-bottom pb-2 mb-3 mt-4"><i class="bi bi-grid-3x3 me-2"></i>Seat Type
                                Configuration</h5>
                            <p class="text-muted small mb-3">Configure different seat categories. Total must not exceed
                                capacity.</p>

                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label for="regularSeats" class="form-label">
                                        <i class="bi bi-circle me-1"></i> Regular Seats
                                    </label>
                                    <input type="number" class="form-control seat-input" id="regularSeats"
                                        name="regularSeats" min="0" value="<%= seatTypeCounts.regular %>"
                                        placeholder="0">
                                </div>

                                <div class="col-md-4 mb-3">
                                    <label for="vipSeats" class="form-label">
                                        <i class="bi bi-star-fill me-1"></i> VIP Seats
                                    </label>
                                    <input type="number" class="form-control seat-input" id="vipSeats" name="vipSeats"
                                        min="0" value="<%= seatTypeCounts.vip %>" placeholder="0">
                                </div>

                                <div class="col-md-4 mb-3">
                                    <label for="wheelchairSeats" class="form-label">
                                        <i class="bi bi-person-wheelchair me-1"></i> Wheelchair Accessible
                                    </label>
                                    <input type="number" class="form-control seat-input" id="wheelchairSeats"
                                        name="wheelchairSeats" min="0" value="<%= seatTypeCounts.wheelchair %>"
                                        placeholder="0">
                                </div>
                            </div>

                            <div id="seatValidation" class="alert alert-success mb-4">
                                <i class="bi bi-check-circle me-2"></i>
                                <strong>Total Configured:</strong> <span id="totalConfigured">0</span> seats
                                / <span id="maxCapacity">
                                    <%= hall.capacity %>
                                </span> capacity
                            </div>

                            <!-- Status and Maintenance -->
                            <h5 class="border-bottom pb-2 mb-3 mt-4"><i class="bi bi-toggle-on me-2"></i>Hall Status
                            </h5>

                            <div class="mb-3">
                                <label for="status" class="form-label">Status <span class="text-danger">*</span></label>
                                <select class="form-select" id="status" name="status" required>
                                    <option value="active" <%=hall.status==='active' ? 'selected' : '' %>>Active
                                    </option>
                                    <option value="maintenance" <%=hall.status==='maintenance' ? 'selected' : '' %>
                                        >Under Maintenance</option>
                                    <option value="cleaning" <%=hall.status==='cleaning' ? 'selected' : '' %>>Cleaning
                                    </option>
                                </select>
                                <div class="form-text">
                                    <span class="badge bg-success me-1">Active</span> Available for screenings
                                    <span class="badge bg-danger me-1 ms-2">Maintenance</span> Not available (requires
                                    schedule)
                                    <span class="badge bg-warning text-dark ms-2">Cleaning</span> Temporarily
                                    unavailable
                                </div>
                            </div>

                            <!-- Maintenance Scheduling -->
                            <div id="maintenanceFields"
                                style="display: <%= hall.status === 'maintenance' ? 'block' : 'none' %>;">
                                <div class="card bg-light mb-3">
                                    <div class="card-body">
                                        <h6 class="card-title"><i class="bi bi-calendar-range me-2"></i>Maintenance
                                            Schedule</h6>

                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label for="maintenanceStartDate" class="form-label">Start Date</label>
                                                <input type="date" class="form-control" id="maintenanceStartDate"
                                                    name="maintenanceStartDate"
                                                    value="<%= hall.maintenanceStartDate ? hall.maintenanceStartDate.toISOString().split('T')[0] : '' %>">
                                            </div>

                                            <div class="col-md-6 mb-3">
                                                <label for="maintenanceEndDate" class="form-label">End Date</label>
                                                <input type="date" class="form-control" id="maintenanceEndDate"
                                                    name="maintenanceEndDate"
                                                    value="<%= hall.maintenanceEndDate ? hall.maintenanceEndDate.toISOString().split('T')[0] : '' %>">
                                            </div>
                                        </div>

                                        <div class="mb-0">
                                            <label for="maintenanceReason" class="form-label">Reason</label>
                                            <textarea class="form-control" id="maintenanceReason"
                                                name="maintenanceReason" rows="2" maxlength="200"
                                                placeholder="e.g., Projector replacement, Seat repairs"><%= hall.maintenanceReason || '' %></textarea>
                                            <div class="form-text">Brief reason for maintenance (max 200 characters)
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Submit Buttons -->
                            <div class="d-flex gap-2 mt-4">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-check-circle me-2"></i> Update Hall
                                </button>
                                <a href="/admin/halls" class="btn btn-secondary">
                                    <i class="bi bi-x-circle me-2"></i> Cancel
                                </a>
                            </div>
                        </form>
            </div>
        </div>
    </div>
</div>

<script>
    // Calculate and display capacity
    function updateCapacity() {
        const rows = parseInt(document.getElementById('rows').value) || 0;
        const columns = parseInt(document.getElementById('columns').value) || 0;
        const capacity = rows * columns;

        document.getElementById('capacityDisplay').textContent =
            `${capacity} seats (${rows} rows × ${columns} columns)`;
        document.getElementById('maxCapacity').textContent = capacity;

        // Update max values for seat inputs
        document.querySelectorAll('.seat-input').forEach(input => {
            input.max = capacity;
        });

        validateSeats();
    }

    // Validate seat type totals
    function validateSeats() {
        const rows = parseInt(document.getElementById('rows').value) || 0;
        const columns = parseInt(document.getElementById('columns').value) || 0;
        const capacity = rows * columns;

        const regular = parseInt(document.getElementById('regularSeats').value) || 0;
        const vip = parseInt(document.getElementById('vipSeats').value) || 0;
        const wheelchair = parseInt(document.getElementById('wheelchairSeats').value) || 0;

        const total = regular + vip + wheelchair;

        document.getElementById('totalConfigured').textContent = total;

        const validationDiv = document.getElementById('seatValidation');

        if (total > capacity) {
            validationDiv.className = 'alert alert-danger mb-4';
            validationDiv.innerHTML = `
                <i class="bi bi-exclamation-triangle me-2"></i>
                <strong>Error:</strong> Total configured (${total}) exceeds capacity (${capacity})
            `;
        } else if (total < capacity && total > 0) {
            validationDiv.className = 'alert alert-warning mb-4';
            validationDiv.innerHTML = `
                <i class="bi bi-info-circle me-2"></i>
                <strong>Total Configured:</strong> ${total} seats / ${capacity} capacity
                (${capacity - total} seats will be regular by default)
            `;
        } else if (total === capacity) {
            validationDiv.className = 'alert alert-success mb-4';
            validationDiv.innerHTML = `
                <i class="bi bi-check-circle me-2"></i>
                <strong>Perfect!</strong> All ${capacity} seats configured
            `;
        } else {
            validationDiv.className = 'alert alert-info mb-4';
            validationDiv.innerHTML = `
                <i class="bi bi-info-circle me-2"></i>
                All ${capacity} seats will be regular (default)
            `;
        }
    }

    // Show/hide maintenance fields based on status
    function updateMaintenanceFields() {
        const status = document.getElementById('status').value;
        const maintenanceFields = document.getElementById('maintenanceFields');

        if (status === 'maintenance') {
            maintenanceFields.style.display = 'block';
            document.getElementById('maintenanceStartDate').required = true;
            document.getElementById('maintenanceEndDate').required = true;
        } else {
            maintenanceFields.style.display = 'none';
            document.getElementById('maintenanceStartDate').required = false;
            document.getElementById('maintenanceEndDate').required = false;
        }
    }

    // Event listeners
    document.getElementById('rows').addEventListener('input', updateCapacity);
    document.getElementById('columns').addEventListener('input', updateCapacity);
    document.querySelectorAll('.seat-input').forEach(input => {
        input.addEventListener('input', validateSeats);
    });
    document.getElementById('status').addEventListener('change', updateMaintenanceFields);

    // Initialize on page load
    updateCapacity();
    validateSeats();
    updateMaintenanceFields();

    // Form validation before submit
    document.getElementById('hallForm').addEventListener('submit', function (e) {
        const rows = parseInt(document.getElementById('rows').value) || 0;
        const columns = parseInt(document.getElementById('columns').value) || 0;
        const capacity = rows * columns;

        const regular = parseInt(document.getElementById('regularSeats').value) || 0;
        const vip = parseInt(document.getElementById('vipSeats').value) || 0;
        const wheelchair = parseInt(document.getElementById('wheelchairSeats').value) || 0;

        const total = regular + vip + wheelchair;

        if (total > capacity) {
            e.preventDefault();
            alert(`Total seat types (${total}) cannot exceed hall capacity (${capacity})`);
            return false;
        }
    });
</script>