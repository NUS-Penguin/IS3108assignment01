<%
// Determine if we're in edit mode or create mode
const isEditMode = typeof hall !== 'undefined' && hall;
const formAction = isEditMode ? `/admin/halls/${hall._id}?_method=PUT` : '/admin/halls';
const formTitle = isEditMode ? 'Edit Cinema Hall' : 'Create New Cinema Hall';
const formIcon = isEditMode ? 'bi-pencil' : 'bi-plus-circle';
const submitButtonText = isEditMode ? 'Update Hall' : 'Create Hall';

// Default values for create mode
const defaultRows = 10;
const defaultColumns = 15;
const defaultCapacity = defaultRows * defaultColumns;

// Use hall data in edit mode, defaults in create mode
const hallName = isEditMode ? hall.name : '';
const hallRows = isEditMode ? hall.rows : defaultRows;
const hallColumns = isEditMode ? hall.columns : defaultColumns;
const hallStatus = isEditMode ? hall.status : 'active';
const hallCapacity = isEditMode ? hall.capacity : defaultCapacity;

// Seat type counts
const seatTypeCounts = isEditMode && seatTypeCounts ? seatTypeCounts : { regular: 130, vip: 15, wheelchair: 5 };
%>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="<%= formIcon %> me-2"></i>
                        <%= formTitle %>
                    </h4>
                </div>
                <div class="card-body">
                    <% if (error) { %>
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <%= error %>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                        <% } %>

                            <form action="<%= formAction %>" method="POST" id="hallForm">

                                <!-- Basic Information -->
                                <h5 class="border-bottom pb-2 mb-3"><i class="bi bi-info-circle me-2"></i>Basic
                                    Information</h5>

                                <div class="mb-3">
                                    <label for="name" class="form-label">Hall Name <span
                                            class="text-danger">*</span></label>
                                    <input type="text" class="form-control" id="name" name="name" required
                                        value="<%= hallName %>" placeholder="e.g., Hall A, IMAX 1">
                                    <div class="form-text">Unique name for the cinema hall.</div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label for="rows" class="form-label">Number of Rows <span
                                                class="text-danger">*</span></label>
                                        <input type="number" class="form-control" id="rows" name="rows" required min="1"
                                            max="26" value="<%= hallRows %>" placeholder="e.g., 10">
                                        <div class="form-text">1-26 rows (A-Z)</div>
                                    </div>

                                    <div class="col-md-6 mb-3">
                                        <label for="columns" class="form-label">Number of Columns <span
                                                class="text-danger">*</span></label>
                                        <input type="number" class="form-control" id="columns" name="columns" required
                                            min="1" max="50" value="<%= hallColumns %>" placeholder="e.g., 20">
                                        <div class="form-text">1-50 columns</div>
                                    </div>
                                </div>

                                <!-- Generate Layout Button (for both create and edit modes) -->
                                <div class="mb-3">
                                    <button type="button" class="btn btn-success" id="generateLayoutBtn">
                                        <i class="bi bi-grid-3x3-gap me-2"></i>Generate Seating Layout
                                    </button>
                                    <div class="form-text">Click to create or reset the seat configuration based on
                                        the dimensions above.</div>
                                </div>

                                <!-- Seat Mode Control Buttons -->
                                <div class="mb-3" id="seatModeControls" style="display: none;">
                                    <h6 class="mb-2">Seat Editing Mode:</h6>
                                    <div class="btn-group" role="group" aria-label="Seat editing modes">
                                        <button type="button" class="btn btn-primary seat-mode-btn active" data-mode="regular">
                                            <i class="bi bi-circle me-1"></i>Add Regular
                                        </button>
                                        <button type="button" class="btn btn-warning seat-mode-btn" data-mode="vip">
                                            <i class="bi bi-star-fill me-1"></i>Add VIP
                                        </button>
                                        <button type="button" class="btn btn-info seat-mode-btn" data-mode="wheelchair">
                                            <i class="bi bi-person-wheelchair me-1"></i>Add Wheelchair
                                        </button>
                                        <button type="button" class="btn btn-secondary seat-mode-btn" data-mode="unavailable">
                                            <i class="bi bi-x-circle me-1"></i>Add Unavailable
                                        </button>
                                        <button type="button" class="btn btn-outline-dark seat-mode-btn" data-mode="empty">
                                            <i class="bi bi-eraser me-1"></i>Clear Seat
                                        </button>
                                    </div>
                                    <div class="form-text mt-2">Select a mode above, then click on seats to change them to that type.</div>
                                </div>

                                        <div class="alert alert-info mb-4">
                                            <i class="bi bi-calculator me-2"></i>
                                            <strong>
                                                <%= isEditMode ? 'Hall Capacity:' : 'Automatic Capacity Calculation:' %>
                                            </strong>
                                            <span id="capacityDisplay">
                                                <%= hallCapacity %> seats (<%= hallRows %> rows × <%= hallColumns %>
                                                            columns)
                                            </span>
                                        </div>

                                        <!-- Seat Type Legend -->
                                        <div class="card bg-light mb-3" id="seatLegend" style="display: none;">
                                            <div class="card-body py-2">
                                                <h6 class="mb-2">Seat Legend:</h6>
                                                <div class="d-flex flex-wrap gap-3">
                                                    <div class="d-flex align-items-center">
                                                        <div class="seat-legend-box seat-regular"></div>
                                                        <span class="ms-2 small">Regular</span>
                                                    </div>
                                                    <div class="d-flex align-items-center">
                                                        <div class="seat-legend-box seat-vip"></div>
                                                        <span class="ms-2 small">VIP</span>
                                                    </div>
                                                    <div class="d-flex align-items-center">
                                                        <div class="seat-legend-box seat-wheelchair"></div>
                                                        <span class="ms-2 small">Wheelchair</span>
                                                    </div>
                                                    <div class="d-flex align-items-center">
                                                        <div class="seat-legend-box seat-unavailable"></div>
                                                        <span class="ms-2 small">Unavailable</span>
                                                    </div>
                                                    <div class="d-flex align-items-center">
                                                        <div class="seat-legend-box seat-empty"></div>
                                                        <span class="ms-2 small">Empty</span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Seat Statistics -->
                                        <div class="alert alert-light border mb-3" id="seatStats" style="display: none;">
                                            <div class="row text-center">
                                                <div class="col-3">
                                                    <div class="fw-bold text-primary" id="regularCount">0</div>
                                                    <small class="text-muted">Regular</small>
                                                </div>
                                                <div class="col-3">
                                                    <div class="fw-bold text-warning" id="vipCount">0</div>
                                                    <small class="text-muted">VIP</small>
                                                </div>
                                                <div class="col-3">
                                                    <div class="fw-bold text-info" id="wheelchairCount">0</div>
                                                    <small class="text-muted">Wheelchair</small>
                                                </div>
                                                <div class="col-3">
                                                    <div class="fw-bold text-secondary" id="unavailableCount">0</div>
                                                    <small class="text-muted">Unavailable</small>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Seating Grid -->
                                        <div class="mb-3" id="seatGridContainer" style="display: none;">
                                            <div class="card">
                                                <div class="card-header bg-dark text-white text-center py-2">
                                                    <small><i class="bi bi-film me-1"></i>SCREEN</small>
                                                </div>
                                                <div class="card-body p-3">
                                                    <!-- Row Labels and Grid Container -->
                                                    <div class="d-flex">
                                                        <div class="seat-row-labels" id="rowLabels"></div>
                                                        <div class="flex-grow-1">
                                                            <!-- Column Labels -->
                                                            <div class="seat-column-labels" id="columnLabels"></div>
                                                            <!-- Seat Grid -->
                                                            <div id="seatGrid" class="seat-grid"></div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Hidden input to store seat matrix -->
                                        <input type="hidden" id="seatMatrix" name="seatMatrix">

                                        <% if (!isEditMode) { %>
                                            <!-- Fallback: Simple Seat Type Configuration (Create Mode Only) -->
                                            <div class="mt-4" id="simpleSeatConfig">
                                                <h6 class="border-bottom pb-2 mb-3"><i class="bi bi-grid-3x3 me-2"></i>Alternative: Simple Seat Configuration</h6>
                                                <p class="text-muted small mb-3">Use these inputs as a fallback if visual configuration is not used.</p>

                                                <div class="row">
                                                    <div class="col-md-4 mb-3">
                                                        <label for="regularSeats" class="form-label">
                                                            <i class="bi bi-circle me-1"></i> Regular Seats
                                                        </label>
                                                        <input type="number" class="form-control seat-input"
                                                            id="regularSeats" name="regularSeats" min="0" value="0"
                                                            placeholder="0">
                                                    </div>

                                                    <div class="col-md-4 mb-3">
                                                        <label for="vipSeats" class="form-label">
                                                            <i class="bi bi-star-fill me-1"></i> VIP Seats
                                                        </label>
                                                        <input type="number" class="form-control seat-input"
                                                            id="vipSeats" name="vipSeats" min="0" value="0"
                                                            placeholder="0">
                                                    </div>

                                                    <div class="col-md-4 mb-3">
                                                        <label for="wheelchairSeats" class="form-label">
                                                            <i class="bi bi-person-wheelchair me-1"></i> Wheelchair Accessible
                                                        </label>
                                                        <input type="number" class="form-control seat-input"
                                                            id="wheelchairSeats" name="wheelchairSeats" min="0"
                                                            value="0" placeholder="0">
                                                    </div>
                                                </div>
                                            </div>
                                        <% } %>

                                                    <!-- Status and Maintenance -->
                                                    <h5 class="border-bottom pb-2 mb-3 mt-4"><i
                                                            class="bi bi-toggle-on me-2"></i>Hall Status</h5>

                                                    <div class="mb-3">
                                                        <label for="status" class="form-label">Status <span
                                                                class="text-danger">*</span></label>
                                                        <select class="form-select" id="status" name="status" required>
                                                            <option value="active" <%=hallStatus==='active' ? 'selected'
                                                                : '' %>>Active</option>
                                                            <option value="maintenance" <%=hallStatus==='maintenance'
                                                                ? 'selected' : '' %>>Under Maintenance</option>
                                                            <option value="cleaning" <%=hallStatus==='cleaning'
                                                                ? 'selected' : '' %>>Cleaning</option>
                                                        </select>
                                                        <div class="form-text">
                                                            <span class="badge bg-success me-1">Active</span> Available
                                                            for screenings
                                                            <span class="badge bg-danger me-1 ms-2">Maintenance</span>
                                                            Not available (requires schedule)
                                                            <span
                                                                class="badge bg-warning text-dark ms-2">Cleaning</span>
                                                            Temporarily unavailable
                                                        </div>
                                                    </div>

                                                    <!-- Maintenance Scheduling -->
                                                    <div id="maintenanceFields"
                                                        style="display: <%= hallStatus === 'maintenance' ? 'block' : 'none' %>;">
                                                        <div class="card bg-light mb-3">
                                                            <div class="card-body">
                                                                <h6 class="card-title"><i
                                                                        class="bi bi-calendar-range me-2"></i>Maintenance
                                                                    Schedule</h6>

                                                                <div class="row">
                                                                    <div class="col-md-6 mb-3">
                                                                        <label for="maintenanceStartDate"
                                                                            class="form-label">Start Date</label>
                                                                        <input type="date" class="form-control"
                                                                            id="maintenanceStartDate"
                                                                            name="maintenanceStartDate"
                                                                            value="<%= isEditMode && hall.maintenanceStartDate ? hall.maintenanceStartDate.toISOString().split('T')[0] : '' %>">
                                                                    </div>

                                                                    <div class="col-md-6 mb-3">
                                                                        <label for="maintenanceEndDate"
                                                                            class="form-label">End Date</label>
                                                                        <input type="date" class="form-control"
                                                                            id="maintenanceEndDate"
                                                                            name="maintenanceEndDate"
                                                                            value="<%= isEditMode && hall.maintenanceEndDate ? hall.maintenanceEndDate.toISOString().split('T')[0] : '' %>">
                                                                    </div>
                                                                </div>

                                                                <div class="mb-0">
                                                                    <label for="maintenanceReason"
                                                                        class="form-label">Reason</label>
                                                                    <textarea class="form-control"
                                                                        id="maintenanceReason" name="maintenanceReason"
                                                                        rows="2" maxlength="200"
                                                                        placeholder="e.g., Projector replacement, Seat repairs"><%= isEditMode && hall.maintenanceReason ? hall.maintenanceReason : '' %></textarea>
                                                                    <div class="form-text">Brief reason for maintenance
                                                                        (max 200 characters)</div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <!-- Submit Buttons -->
                                                    <div class="d-flex gap-2 mt-4">
                                                        <button type="submit" class="btn btn-primary">
                                                            <i class="bi bi-check-circle me-2"></i>
                                                            <%= submitButtonText %>
                                                        </button>
                                                        <a href="/admin/halls" class="btn btn-outline-secondary">
                                                            <i class="bi bi-x-circle me-2"></i>Cancel
                                                        </a>
                                                    </div>
                            </form>
                </div>
            </div>
        </div>
    </div>

    <% if (isEditMode) { %>
        <style>
            .seat-grid {
                display: flex;
                flex-direction: column;
                gap: 8px;
                max-width: 100%;
                overflow-x: auto;
            }

            .seat-row {
                display: flex;
                gap: 6px;
                align-items: center;
            }

            .seat-row-label {
                width: 30px;
                font-weight: bold;
                text-align: right;
                font-size: 0.875rem;
            }

            .seat {
                width: 32px;
                height: 32px;
                border: 2px solid #dee2e6;
                border-radius: 6px;
                cursor: pointer;
                transition: all 0.15s ease;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 0.75rem;
                font-weight: bold;
            }

            .seat:hover {
                transform: scale(1.1);
                box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
            }

            .seat-regular {
                background-color: #0d6efd;
                border-color: #0d6efd;
                color: white;
            }

            .seat-vip {
                background-color: #ffc107;
                border-color: #ffc107;
                color: #000;
            }

            .seat-wheelchair {
                background-color: #0dcaf0;
                border-color: #0dcaf0;
                color: #000;
            }

            .seat-unavailable {
                background-color: #6c757d;
                border-color: #6c757d;
                color: white;
            }

            .seat-legend-box {
                width: 20px;
                height: 20px;
                border-radius: 4px;
            }
        </style>
        <% } %>

            <script>
                const isEditMode = <%= isEditMode ? 'true' : 'false' %>;

                // Form validation and maintenance logic

                document.addEventListener('DOMContentLoaded', function () {
                    // Update capacity display when dimensions change
                    function updateCapacity() {
                        const rows = parseInt(document.getElementById('rows').value) || 0;
                        const columns = parseInt(document.getElementById('columns').value) || 0;
                        const capacity = rows * columns;
                        
                        document.getElementById('capacityDisplay').textContent = 
                            `${capacity} seats (${rows} rows × ${columns} columns)`;
                    }

                    // Update maintenance fields visibility
                    function updateMaintenanceFields() {
                        const status = document.getElementById('status').value;
                        const maintenanceFields = document.getElementById('maintenanceFields');

                        if (maintenanceFields) {
                            if (status === 'maintenance') {
                                maintenanceFields.style.display = 'block';
                                document.getElementById('maintenanceStartDate').required = true;
                                document.getElementById('maintenanceEndDate').required = true;
                            } else {
                                maintenanceFields.style.display = 'none';
                                document.getElementById('maintenanceStartDate').required = false;
                                document.getElementById('maintenanceEndDate').required = false;
                            }
                        }
                    }

                    // Event listeners
                    document.getElementById('rows').addEventListener('input', updateCapacity);
                    document.getElementById('columns').addEventListener('input', updateCapacity);
                    document.getElementById('status').addEventListener('change', updateMaintenanceFields);

                    // Initialize on page load
                    updateCapacity();
                    updateMaintenanceFields();
                });











                    function updateMaintenanceFields() {
                        const status = document.getElementById('status').value;
                        const maintenanceFields = document.getElementById('maintenanceFields');

                        if (status === 'maintenance') {
                            maintenanceFields.style.display = 'block';
                            document.getElementById('maintenanceStartDate').required = true;
                            document.getElementById('maintenanceEndDate').required = true;
                        } else {
                            maintenanceFields.style.display = 'none';
                            document.getElementById('maintenanceStartDate').required = false;
                            document.getElementById('maintenanceEndDate').required = false;
                        }
                    }

                // Seat Matrix Configuration Data
                <% if (isEditMode && typeof seatMatrix !== 'undefined' && seatMatrix) { %>
                    // Pass existing seat matrix data to JavaScript
                    window.seatMatrix = <%- JSON.stringify(seatMatrix) %>;
                <% } %>
            </script>