<div class="page-header">
    <h1>Dashboard</h1>
    <p>Welcome back, <%= user.username %>. Monitor key activity and upcoming screenings.</p>
</div>

<div class="market-stats">
    <div class="market-stat">
        <div class="market-stat-label">Total Movies</div>
        <div class="market-stat-value"><%= stats.activeMovies %></div>
        <div class="market-stat-change positive">Catalogue size</div>
    </div>
    <div class="market-stat">
        <div class="market-stat-label">Active Halls</div>
        <div class="market-stat-value"><%= stats.activeHalls %></div>
        <div class="market-stat-change positive">Available now</div>
    </div>
    <div class="market-stat">
        <div class="market-stat-label">Screenings Today</div>
        <div class="market-stat-value"><%= stats.screeningsToday %></div>
        <div class="market-stat-change positive">Scheduled sessions</div>
    </div>
</div>

<div class="action-buttons">
    <a href="/admin/screenings/new" class="action-btn primary">New Screening</a>
    <a href="/admin/movies/new" class="action-btn">Add Movie</a>
    <a href="/admin/halls/new" class="action-btn">Add Hall</a>
</div>

<div class="card">
    <div class="section-header">
        <h2 class="card-title">Upcoming Screenings</h2>
    </div>

    <% if (upcomingScreenings && upcomingScreenings.length > 0) { %>
        <div class="table-responsive">
            <table class="market-table">
                <thead>
                    <tr>
                        <th>Movie</th>
                        <th>Hall</th>
                        <th>Start Time</th>
                        <th>Duration</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% upcomingScreenings.forEach(screening => { %>
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <% const posterSrc = screening.movie.posterPath || screening.movie.posterURL || 'https://via.placeholder.com/48x68?text=N/A'; %>
                                    <img
                                        src="<%= posterSrc %>"
                                        alt="<%= screening.movie.title %> poster"
                                        width="48"
                                        height="68"
                                        onerror="this.src='https://via.placeholder.com/48x68?text=N/A'">
                                    <div>
                                        <div class="fw-semibold"><%= screening.movie.title %></div>
                                        <small class="text-muted">
                                            <%= screening.movie.description
                                                ? (screening.movie.description.length > 60
                                                    ? screening.movie.description.substring(0, 60) + '…'
                                                    : screening.movie.description)
                                                : (screening.movie.genre || 'No description') %>
                                        </small>
                                    </div>
                                </div>
                            </td>
                            <td><%= screening.hall.name %></td>
                            <td><%= screening.startTime.toLocaleString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></td>
                            <td><%= screening.movie.durationMinutes %> min</td>
                            <td>
                                <form action="/admin/screenings/<%= screening._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this screening?');">
                                    <input type="hidden" name="redirectTo" value="dashboard">
                                    <button type="submit" class="action-btn">Delete</button>
                                </form>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    <% } else { %>
        <p class="header-subtitle">No upcoming screenings scheduled.</p>
    <% } %>
</div>
