<div class="auth-branding">
    <div class="branding-content">
        <div class="branding-logo">CV</div>
        <h1 class="branding-title">CineVillage</h1>
        <p class="branding-subtitle">Set a secure new password for your administrator account.</p>
    </div>
</div>

<div class="auth-form-container">
    <button class="theme-toggle-btn" id="themeToggle" type="button" aria-label="Toggle theme">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/>
            <line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/>
            <line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
    </button>

    <div class="auth-form-wrapper">
        <div class="form-header">
            <h1>Reset Password</h1>
            <p>Enter your new password to complete account recovery.</p>
        </div>

        <% if (error) { %>
            <div class="alert alert-danger" role="alert"><%= error %></div>
        <% } %>

        <% if (typeof validToken !== 'undefined' && validToken) { %>
            <div class="alert alert-info mb-3">
                <strong>Password Requirements:</strong>
                <ul class="mb-0 mt-2">
                    <li>At least 8 characters long</li>
                    <li>At least one uppercase letter</li>
                    <li>At least one number</li>
                    <li>At least one special character</li>
                </ul>
            </div>

            <form class="auth-form active" action="/reset-password/<%= token %>" method="POST">
                <div class="form-group">
                    <label class="form-label" for="password">New Password</label>
                    <div class="form-input-wrapper">
                        <input type="password" class="form-input" id="password" name="password" required autofocus placeholder="Enter new password">
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label" for="confirmPassword">Confirm New Password</label>
                    <div class="form-input-wrapper">
                        <input type="password" class="form-input" id="confirmPassword" name="confirmPassword" required placeholder="Confirm new password">
                    </div>
                </div>

                <button type="submit" class="submit-btn">Reset Password</button>
            </form>
        <% } else { %>
            <div class="alert alert-warning" role="alert">
                The password reset link is invalid or has expired.
            </div>
            <a href="/forgot-password" class="submit-btn d-inline-block text-center">Request New Link</a>
        <% } %>

        <p class="form-footer">
            <a href="/login">Back to Login</a>
        </p>
    </div>
</div>