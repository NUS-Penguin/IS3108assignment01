<div class="header">
    <div class="header-right ms-auto">
        <div class="user-menu">
            <div class="user-avatar"><%= (user && user.username ? user.username.substring(0, 2) : 'AD').toUpperCase() %></div>
            <div class="user-info">
                <span class="user-name"><%= user && user.username ? user.username : 'Administrator' %></span>
                <span class="user-role"><%= user && user.role ? user.role : 'manager' %></span>
            </div>
        </div>
    </div>
</div>
