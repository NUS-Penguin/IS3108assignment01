exports.renderForm = async (req, res, next) => {
    try {
        const isEditMode = !!req.params.id;
        
        if (isEditMode) {
            // Edit mode - fetch and prepare hall data
            const hall = await Hall.findById(req.params.id);
            const seatTypeCounts = { /* extract counts */ };
            const seatMap = hall.seatMap || [];
            
            res.render('halls/form', { hall, seatTypeCounts, seatMap, ... });
        } else {
            // Create mode - no data needed
            res.render('halls/form', { ... });
        }
    } catch (error) {
        next(error);
    }
};
```

